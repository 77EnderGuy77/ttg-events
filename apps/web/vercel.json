{
  "buildCommand": "npm run build -w apps/web",
  "outputDirectory": "apps/web/dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Android|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini|Mobile|mobile).*"
        }
      ],
      "destination": "https://ttg-events-mobile.vercel.app/$1",
      "permanent": false
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
